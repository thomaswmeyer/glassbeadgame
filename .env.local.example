# LLM provider API keys. Configure only the providers you use.
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model keys: gemini_flash, gemini_pro, openai_frontier, openai_fast,
# claude_opus, claude_sonnet.
GBG_DEFAULT_AI_MODEL_KEY=gemini_flash
GBG_JUDGE_MODEL_KEY=gemini_flash
GBG_TOPIC_MODEL_KEY=gemini_flash
GBG_DEFINITION_MODEL_KEY=gemini_flash

# Public model keys used when the browser creates default AI players.
NEXT_PUBLIC_GBG_DEFAULT_AI_MODEL_KEY=gemini_flash
NEXT_PUBLIC_GBG_AI_PLAYER_1_MODEL_KEY=gemini_flash
NEXT_PUBLIC_GBG_AI_PLAYER_2_MODEL_KEY=gemini_flash

# Optional provider model-id overrides.
GEMINI_FLASH_MODEL=gemini-2.5-flash-lite
GEMINI_PRO_MODEL=gemini-2.5-pro
OPENAI_FRONTIER_MODEL=gpt-5.2
OPENAI_FAST_MODEL=gpt-5-mini
ANTHROPIC_OPUS_MODEL=claude-opus-4-1-20250805
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514

# Local SQLite database path. Production can use a Postgres DATABASE_URL later.
DATABASE_URL=file:./data/glassbeadgame.dev.sqlite
