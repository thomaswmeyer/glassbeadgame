# Google Gemini API Key - Get one at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Defaults to gemini-3.1-flash-lite.
# Use gemini-2.5-pro when you want the higher-end Gemini reasoning model.
GEMINI_MODEL=gemini-3.1-flash-lite

# Local SQLite database path. Production can use a Postgres DATABASE_URL later.
DATABASE_URL=file:./data/glassbeadgame.dev.sqlite
